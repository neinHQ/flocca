{
    "cleanUrls": true,
    "trailingSlash": true,
    "redirects": [
        {
            "source": "/docs",
            "destination": "/docs/"
        }
    ],
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "https://api.flocca.app/$1"
        },
        {
            "source": "/docs/",
            "destination": "/docs/index.html"
        }
    ],
    "functions": {
        "api/stats.js": {
            "memory": 256,
            "maxDuration": 10
        }
    }
}
